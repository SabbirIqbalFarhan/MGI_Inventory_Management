<div style="text-align:center; margin-bottom:15px;">
    <a asp-controller="Admin" asp-action="Index"
           style="display:inline-flex; align-items:center; gap:8px;
        background:linear-gradient(135deg,#00aaff,#0077cc);
        color:#fff; font-weight:600;
        padding:9px 24px; border-radius:50px; text-decoration:none;
        font-size:0.9rem; letter-spacing:0.4px;
        box-shadow:0 4px 14px rgba(0,170,255,0.4);
        transition:all 0.2s ease;"
           onmouseover="this.style.boxShadow='0 6px 20px rgba(0,170,255,0.55)'; this.style.transform='translateY(-1px)'"
           onmouseout="this.style.boxShadow='0 4px 14px rgba(0,170,255,0.4)'; this.style.transform='translateY(0)'">
        <i class="bi bi-arrow-left-circle-fill" style="font-size:1rem;"></i>
        Back to Dashboard
    </a>
</div>