<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Meghna Group - Vision Mission Goals</title>

    <!-- Bootstrap 5 -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">

    <style>
        body {
            font-family: 'Segoe UI', sans-serif;
            background: #f8f9fa;
        }

        .section-title {
            font-weight: 700;
            text-align: center;
            margin-bottom: 40px;
            color: #0d6efd;
        }

        .card-custom {
            border: none;
            border-radius: 15px;
            transition: 0.3s;
            box-shadow: 0 5px 20px rgba(0,0,0,0.08);
            padding: 25px;
            background: white;
        }

        .card-custom:hover {
            transform: translateY(-8px);
        }

        .icon-box {
            font-size: 40px;
            color: #0d6efd;
            margin-bottom: 15px;
        }

        .card-title {
            font-weight: 600;
            margin-bottom: 15px;
        }

        .card-text {
            color: #555;
            font-size: 15px;
        }
    </style>
</head>
<body>

    <section class="container py-5">
        <h2 class="section-title">Our Vision, Mission & Goals</h2>

        <div class="row g-4">

            <!-- Vision -->
            <div class="col-md-4">
                <div class="card-custom text-center h-100">
                    <div class="icon-box">🌍</div>
                    <h5 class="card-title">Vision</h5>
                    <p class="card-text">
                        To be a leading global conglomerate from Bangladesh, delivering excellence
                        through innovation, sustainability, and customer satisfaction while contributing
                        to national economic growth.
                    </p>
                </div>
            </div>

            <!-- Mission -->
            <div class="col-md-4">
                <div class="card-custom text-center h-100">
                    <div class="icon-box">🎯</div>
                    <h5 class="card-title">Mission</h5>
                    <p class="card-text">
                        To provide high-quality products and services across diverse industries by
                        leveraging advanced technology, skilled workforce, and efficient management
                        practices while ensuring value for stakeholders.
                    </p>
                </div>
            </div>

            <!-- Goals -->
            <div class="col-md-4">
                <div class="card-custom text-center h-100">
                    <div class="icon-box">🚀</div>
                    <h5 class="card-title">Goals</h5>
                    <p class="card-text">
                        • Expand global market presence<br>
                        • Maintain highest quality standards<br>
                        • Promote sustainable business practices<br>
                        • Enhance customer satisfaction<br>
                        • Foster innovation and growth
                    </p>
                </div>
            </div>

        </div>
    </section>

</body>
</html>