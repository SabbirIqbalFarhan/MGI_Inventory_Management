@{
    ViewData["Title"] = "Privacy Policy";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Privacy Policy</title>

    <!-- Bootstrap -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">

    <style>
        body {
            background: linear-gradient(to right, #eef2f3, #dfe9f3);
        }

        .card {
            border: none;
            border-radius: 15px;
        }

        .section-title {
            color: #0d6efd;
            font-weight: 600;
        }
    </style>
</head>
<body>

    <div class="container py-5">
        <div class="card shadow-lg p-5">

            <div class="text-center mb-4">
                <h2 class="fw-bold">Privacy Policy</h2>
                <p class="text-muted">Meghna Group of Industries - Inventory System</p>
            </div>

            <div class="mb-4">
                <h5 class="section-title">🔒 Data Protection</h5>
                <p class="text-muted">
                    We prioritize the security and confidentiality of all operational and user data within our inventory system.
                </p>
            </div>

            <div class="mb-4">
                <h5 class="section-title">📊 Information Usage</h5>
                <p class="text-muted">
                    Data collected is used strictly for inventory tracking, reporting, and improving business efficiency.
                </p>
            </div>

            <div class="mb-4">
                <h5 class="section-title">🛡️ Security Measures</h5>
                <p class="text-muted">
                    Advanced security practices are implemented to prevent unauthorized access and ensure system integrity.
                </p>
            </div>

            <div class="mb-4">
                <h5 class="section-title">🤝 Confidentiality</h5>
                <p class="text-muted">
                    All internal data remains confidential and is accessible only to authorized personnel.
                </p>
            </div>

            <div class="mb-4">
                <h5 class="section-title">🔄 Updates</h5>
                <p class="text-muted">
                    This policy may be updated periodically to comply with company standards and regulations.
                </p>
            </div>

            <div class="text-center mt-4">
                <a href="/Home/Index" class="btn btn-primary px-4">Back to Dashboard</a>
            </div>

        </div>
    </div>

</body>
</html>