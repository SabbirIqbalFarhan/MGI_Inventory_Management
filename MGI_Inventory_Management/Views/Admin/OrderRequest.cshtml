@using MGI_Inventory_Management.Models
@await Html.PartialAsync("_BackButton")

<div class="container mt-4">
    <div class="p-3 text-white rounded shadow mb-4" style="background:#00aaff;">
        <h4 class="mb-0">Order Requests</h4>
    </div>

    @if (TempData["OrderSuccess"] != null)
    {
        <div class="alert alert-success">@TempData["OrderSuccess"]</div>
    }
    @if (TempData["OrderError"] != null)
    {
        <div class="alert alert-danger">@TempData["OrderError"]</div>
    }

    <div class="text-end mb-3">
        <a asp-action="Order" class="btn btn-primary">
            <i class="bi bi-plus-lg me-1"></i>Make New Order
        </a>
    </div>

    @{
        var allLogs = ViewBag.ActivityLogs as List<OrderActivityLog>
                      ?? new List<OrderActivityLog>();
    }

    @if (ViewBag.Orders != null && ((IEnumerable<dynamic>)ViewBag.Orders).Any())
    {
        @foreach (var order in ViewBag.Orders)
        {
            string status = order.Status;
            string badgeCss = status == "Pending"
                ? "background:#ffc107;color:#000;"
                : status == "Approved"
                    ? "background:#0d6efd;color:#fff;"
                    : "background:#198754;color:#fff;";

            // Format: first 4 digits = order id, next 2 = month, last 4 = year
            DateTime orderDate = (DateTime)order.OrderDate;
            string orderNumber = $"{(int)order.Id:D4}{orderDate.Month:D2}{orderDate.Year}";

            var orderLogs = allLogs.Where(l => l.OrderId == (int)order.Id).ToList();

            <div class="card shadow mb-4">

                <div class="card-header d-flex justify-content-between align-items-center"
                     style="background:#f0f8ff;">
                    <div style="font-size:0.95rem;">
                        <strong>Order #@orderNumber</strong>
                        &nbsp;|&nbsp; @order.OrderedBy
                        &nbsp;|&nbsp;
                        <small class="text-muted">
                            @orderDate.ToString("dd MMM yyyy hh:mm tt")
                        </small>
                    </div>
                    <span style="@badgeCss padding:4px 14px;
                        border-radius:50px; font-size:0.82rem;
                        font-weight:600;">
                        @status
                    </span>
                </div>

                <div class="card-body pb-2">
                    <div class="table-responsive">
                        <table class="table table-bordered table-sm mb-2">
                            <thead class="table-dark">
                                <tr>
                                    <th>#</th>
                                    <th>Category</th>
                                    <th>Product</th>
                                    <th>Qty</th>
                                    <th>Unit Price (৳)</th>
                                    <th>Line Total (৳)</th>
                                </tr>
                            </thead>
                            <tbody>
                                @{
                                    int s = 1;
                                }
                                @foreach (var item in order.Items)
                                {
                                    <tr>
                                        <td>@s</td>
                                        <td>@item.Category?.Name</td>
                                        <td>@item.ProductName</td>
                                        <td>@item.Quantity</td>
                                        <td>@item.SellingPrice.ToString("F2")</td>
                                        <td>@((item.Quantity * item.SellingPrice).ToString("F2"))</td>
                                    </tr>
                                    s++;
                                }
                            </tbody>
                            <tfoot>
                                <tr>
                                    <td colspan="5" class="text-end fw-bold">Grand Total:</td>
                                    <td class="fw-bold" style="color:#00aaff;">
                                        ৳ @((order.Items as IEnumerable<OrderItem>)
                                                                                    .Sum(i => i.Quantity * i.SellingPrice).ToString("F2"))
                                    </td>
                                </tr>
                            </tfoot>
                        </table>
                    </div>

                    <!-- ACTION BUTTONS -->
                    <div class="d-flex gap-2 flex-wrap mt-2">

                        @if (status == "Pending")
                        {
                            @if (User.IsInRole("Admin") || User.IsInRole("Manager"))
                            {
                                <form asp-action="ApproveOrder" method="post">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="id" value="@order.Id" />
                                    <button type="submit" class="btn btn-sm btn-success">
                                        <i class="bi bi-check-lg me-1"></i>Approve
                                    </button>
                                </form>
                            }

                            <a asp-action="EditOrder" asp-route-id="@order.Id"
                                   class="btn btn-sm btn-warning">
                                <i class="bi bi-pencil-fill me-1"></i>Edit
                            </a>

                            <form asp-action="DeleteOrder" method="post"
                                  onsubmit="return confirm('Delete this order?')">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="id" value="@order.Id" />
                                <button type="submit" class="btn btn-sm btn-danger">
                                    <i class="bi bi-trash-fill me-1"></i>Delete
                                </button>
                            </form>
                        }

                        @if (status == "Approved")
                        {
                            @if (User.IsInRole("Admin") || User.IsInRole("Manager") || User.IsInRole("Seller"))
                            {
                                <form asp-action="DeliverOrder" method="post">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="id" value="@order.Id" />
                                    <button type="submit" class="btn btn-sm btn-primary">
                                        <i class="bi bi-truck me-1"></i>Mark as Delivered
                                    </button>
                                </form>
                            }
                        }

                        @if (status == "Delivered")
                        {
                            <span class="text-success fw-bold">
                                <i class="bi bi-check-circle-fill me-1"></i>
                                Delivered & Stock Updated
                            </span>
                        }

                        <!-- Download Invoice -->
                        <a asp-action="DownloadOrderInvoice" asp-route-id="@order.Id"
                               class="btn btn-sm btn-outline-secondary ms-auto">
                            <i class="bi bi-download me-1"></i>Invoice
                        </a>
                    </div>

                    <!-- ACTIVITY LOG — Admin only -->
                    @if (User.IsInRole("Admin") && orderLogs.Any())
                    {
                        <div style="margin-top:16px; border-top:1px solid #e0e0e0;
                            padding-top:12px;">
                            <div style="font-size:0.8rem; font-weight:700;
                                color:#888; margin-bottom:8px;
                                text-transform:uppercase; letter-spacing:0.05em;">
                                Activity Log
                            </div>
                            <div style="display:flex; flex-direction:column; gap:6px;">
                                @foreach (var log in orderLogs)
                                {
                                    string dotColor =
                                        log.Action == "Created" ? "#6c757d" :
                                        log.Action == "Approved" ? "#198754" :
                                        log.Action == "Edited" ? "#ffc107" :
                                        log.Action == "Deleted" ? "#dc3545" :
                                        log.Action == "Delivered" ? "#0d6efd" : "#aaa";

                                    string actionBadge =
                                        log.Action == "Created" ? "bg-secondary" :
                                        log.Action == "Approved" ? "bg-success" :
                                        log.Action == "Edited" ? "bg-warning text-dark" :
                                        log.Action == "Deleted" ? "bg-danger" :
                                        log.Action == "Delivered" ? "bg-primary" : "bg-light";

                                    <div style="display:flex; align-items:center;
                                        gap:10px; font-size:0.82rem;">
                                        <span style="width:10px; height:10px;
                                        border-radius:50%;
                                        background:@dotColor;
                                        flex-shrink:0;"></span>
                                        <span class="badge @actionBadge"
                                              style="font-size:0.75rem; min-width:68px;">
                                            @log.Action
                                        </span>
                                        <span style="color:#555;">
                                            by <strong style="color:#1a1a1a;">
                                            @log.PerformedBy
                                        </strong>
                                    </span>
                                    <span style="color:#aaa; margin-left:auto;">
                                        @log.PerformedAt.ToString("dd MMM yyyy hh:mm tt")
                                    </span>
                                </div>
                            }
                        </div>
                    </div>
                }
            </div>
        </div>
    }

    <!-- PAGINATION -->
    <div style="display:flex; gap:8px; flex-wrap:wrap; margin-top:10px;">
        @if (ViewBag.CurrentPage > 1)
        {
            <a asp-action="OrderRequest"
               asp-route-page="@(ViewBag.CurrentPage - 1)"
               class="btn btn-sm btn-outline-primary">&#8592; Prev</a>
        }
        @for (int i = 1; i <= ViewBag.TotalPages; i++)
        {
            <a asp-action="OrderRequest"
               asp-route-page="@i"
               class="btn btn-sm @(i == (int)ViewBag.CurrentPage
                                                      ? "btn-primary" : "btn-outline-primary")">@i</a>
    }
    @if (ViewBag.CurrentPage < ViewBag.TotalPages)
    {
        <a asp-action="OrderRequest"
           asp-route-page="@(ViewBag.CurrentPage + 1)"
           class="btn btn-sm btn-outline-primary">Next &#8594;</a>
    }
</div>
    }
    else
{
    <div class="alert alert-info">No order requests yet.</div>
}
</div>