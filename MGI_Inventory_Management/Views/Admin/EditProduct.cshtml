@model MGI_Inventory_Management.Models.AddProduct
@await Html.PartialAsync("_BackButton")

<div class="container mt-4">
    <div class="p-3 text-white rounded shadow mb-4" style="background:#00aaff;">
        <h4 class="mb-0">Edit Product</h4>
    </div>

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger">@TempData["ErrorMessage"]</div>
    }

    <div class="card p-4 shadow">

        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

        <form asp-action="EditProduct" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="Id" />

            <div class="mb-3">
                <label class="fw-bold form-label">Product Name</label>
                <input asp-for="Name" class="form-control" readonly
                       style="background:#f0f0f0; cursor:not-allowed;" />
            </div>

            <div class="mb-3">
                <label asp-for="CategoryId" class="fw-bold form-label">Category</label>
                <select asp-for="CategoryId" class="form-select">
                    <option value="">-- Select Category --</option>
                    @foreach (var item in ViewBag.Categories)
                    {
                        <option value="@item.Id">@item.Name</option>
                    }
                </select>
                <span asp-validation-for="CategoryId" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Quantity" class="fw-bold form-label">
                    Quantity Adjustment
                </label>
                <input asp-for="Quantity" class="form-control" type="number" />
                <small class="text-muted">
                    Enter a <strong>positive number</strong> to add stock (e.g. +10),
                    or a <strong>negative number</strong> to subtract stock (e.g. -5).
                    The result cannot go below zero.
                </small>
                <span asp-validation-for="Quantity" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="PurchaseRate" class="fw-bold form-label">
                    Purchase Rate (BDT)
                </label>
                <input asp-for="PurchaseRate" class="form-control"
                       type="number" step="0.01" min="0" />
                <small class="text-muted">
                    This will replace the previous purchase rate going forward.
                </small>
                <span asp-validation-for="PurchaseRate" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="SellingPrice" class="fw-bold form-label">
                    Selling Price (BDT)
                </label>
                <input asp-for="SellingPrice" class="form-control"
                       type="number" step="0.01" min="0" />
                <small class="text-muted">
                    This will replace the previous selling price going forward.
                </small>
                <span asp-validation-for="SellingPrice" class="text-danger"></span>
            </div>

            <hr />

            <div class="d-flex gap-2">
                <button type="submit" class="btn text-white px-4"
                        style="background:#00aaff;">
                    Update Product
                </button>
                <a asp-controller="Admin" asp-action="ViewProduct"
                       class="btn btn-outline-secondary px-4">
                    Cancel
                </a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}