@await Html.PartialAsync("_BackButton")

<div class="container mt-4">

    <div class="p-3 text-white rounded shadow mb-4" style="background:#00aaff;">
        <h4 class="mb-0">Manage Master Products</h4>
    </div>

    @if (TempData["MasterSuccess"] != null)
    {
        <div class="alert alert-success">@TempData["MasterSuccess"]</div>
    }
    @if (TempData["MasterError"] != null)
    {
        <div class="alert alert-danger">@TempData["MasterError"]</div>
    }

    <!-- ADD PRODUCT MASTER FORM -->
    <div class="card p-4 shadow mb-4">
        <h5 style="color:#00aaff;">Add Product to Master List</h5>
        <form asp-action="AddProductMaster" method="post" enctype="multipart/form-data">
            @Html.AntiForgeryToken()

            <div class="row g-3 align-items-end">

                <div class="col-md-3">
                    <label class="form-label fw-bold">Product Name</label>
                    <input type="text" name="productName" class="form-control"
                           placeholder="e.g. Fresh Drinking Water" required />
                </div>

                <div class="col-md-2">
                    <label class="form-label fw-bold">Category</label>
                    <select name="categoryId" class="form-select" required>
                        <option value="">-- Select --</option>
                        @foreach (var cat in ViewBag.Categories)
                        {
                            <option value="@cat.Id">@cat.Name</option>
                        }
                    </select>
                </div>

                <div class="col-md-3">
                    <label class="form-label fw-bold">Description</label>
                    <input type="text" name="description" class="form-control"
                           placeholder="e.g. Mineral water 500ml" required />
                </div>

                <!-- Image + Add button together in one col as a flex row -->
                <div class="col-md-4">
                    <label class="form-label fw-bold">Product Image</label>
                    <div class="d-flex align-items-center gap-2">
                        <input type="file" name="imageFile" accept="image/*" id="imageInput"
                               style="height:38px; padding:4px 6px; font-size:0.875rem;
                        border:1px solid #ced4da; border-radius:6px; flex:1; min-width:0;" />
                        <img id="imagePreview" src="#" alt="Preview"
                             style="width:38px; height:38px; object-fit:cover;
                        border-radius:8px; display:none;
                        border:1px solid #dee2e6; flex-shrink:0;" />
                        <!-- Add button is INSIDE the same flex row as the file input -->
                        <button type="submit" class="btn btn-primary flex-shrink-0"
                                style="height:38px; padding:0 18px;">
                            Add
                        </button>
                    </div>
                </div>

            </div>
        </form>
    </div>

    <!-- PRODUCT MASTER TABLE -->
    <div class="card p-4 shadow mb-4">
        <h5 style="color:#00aaff;">Master Product List</h5>

        @if (ViewBag.ProductMasters != null &&
             ((IEnumerable<dynamic>)ViewBag.ProductMasters).Any())
        {
            <table class="table table-bordered table-hover mt-2">
                <thead class="table-dark">
                    <tr>
                        <th>#</th>
                        <th>Image</th>
                        <th>Product Name</th>
                        <th>Category</th>
                        <th>Description</th>
                        <!-- FIX 2: Removed "Added By" and "Added At" columns -->
                        <th>Action</th>
                    </tr>
                </thead>
                <tbody>
                    @{
                        int i = (ViewBag.CurrentPage - 1) * 10 + 1;
                    }
                    @foreach (var item in ViewBag.ProductMasters)
                    {
                        <tr>
                            <td>@i</td>
                            <td>
                                @if (item.ImagePath != null)
                                {
                                    <img src="@item.ImagePath"
                                         alt="@item.ProductName"
                                         style="width:48px; height:48px;
                                    object-fit:cover; border-radius:8px;" />
                                }
                                else
                                {
                                    <div style="width:48px; height:48px;
                                        border-radius:8px; background:#f0f0f0;
                                        display:flex; align-items:center;
                                        justify-content:center;">
                                        <i class="bi bi-image text-muted"></i>
                                    </div>
                                }
                            </td>
                            <td>@item.ProductName</td>
                            <td>@item.Category.Name</td>
                            <td>@item.Description</td>
                            <!-- FIX 2: Removed Added By and Added At <td> cells -->
                            <td>
                                <form asp-action="DeleteProductMaster"
                                      method="post" style="display:inline"
                                      onsubmit="return confirm('Remove this product?')">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="id" value="@item.Id" />
                                    <button type="submit" class="btn btn-sm btn-danger">
                                        Remove
                                    </button>
                                </form>
                            </td>
                        </tr>
                        i++;
                    }
                </tbody>
            </table>

            <!-- PAGINATION -->
            <div style="display:flex; gap:8px; flex-wrap:wrap; margin-top:10px;">
                @if (ViewBag.CurrentPage > 1)
                {
                    <a href="@Url.Action("ManageProducts", new { page = ViewBag.CurrentPage - 1 })"
                       class="btn btn-sm btn-outline-primary">&#8592; Prev</a>
                }
                @for (int p = 1; p <= ViewBag.TotalPages; p++)
                {
                    <a href="@Url.Action("ManageProducts", new { page = p })"
                       class="btn btn-sm @(p == (int)ViewBag.CurrentPage ? "btn-primary" : "btn-outline-primary")">@p</a>
                }
                @if (ViewBag.CurrentPage < ViewBag.TotalPages)
                {
                    <a href="@Url.Action("ManageProducts", new { page = ViewBag.CurrentPage + 1 })"
                       class="btn btn-sm btn-outline-primary">Next &#8594;</a>
                }
            </div>
        }
        else
        {
            <p class="text-muted mt-2">No products in master list yet.</p>
        }
    </div>

    <!-- ACTIVITY LOG — Admin only -->
    @if (User.IsInRole("Admin"))
    {
        <div class="card p-4 shadow">
            <h5 style="color:#00aaff;">
                <i class="bi bi-journal-text me-2"></i>
                Product Master Activity Log
            </h5>

            @if (ViewBag.ProductMasterLogs != null &&
                 ((IEnumerable<dynamic>)ViewBag.ProductMasterLogs).Any())
            {
                <div class="mt-3">
                    @foreach (var log in ViewBag.ProductMasterLogs)
                    {
                        bool isAdded = log.Action.ToString() == "Added";

                        <div style="display:flex; gap:14px; align-items:center; margin-bottom:14px;">

                            <!-- ICON CIRCLE -->
                            <div style="width:38px; height:38px; border-radius:50%;
                                background:@(isAdded ? "#198754" : "#dc3545");
                                display:flex; align-items:center;
                                justify-content:center; flex-shrink:0;">
                                <i class="bi @(isAdded ? "bi-plus-lg" : "bi-trash")"
                                   style="color:white; font-size:0.9rem;"></i>
                            </div>

                            <!-- LOG BUBBLE -->
                            <div style="flex:1; background:#f8f9fa; border-radius:8px; padding:10px 14px;">
                                <div style="display:flex; justify-content:space-between;
                                    flex-wrap:wrap; gap:8px; align-items:center;">

                                    <!-- LEFT: image + text -->
                                    <div style="display:flex; align-items:center; gap:10px; flex-wrap:wrap;">
                                        @if (log.ImagePath != null)
                                        {
                                            <img src="@log.ImagePath" alt="@log.ProductName"
                                                 style="width:42px; height:42px; object-fit:cover;
                                            border-radius:6px; border:1px solid #dee2e6;" />
                                        }
                                        else
                                        {
                                            <div style="width:42px; height:42px; border-radius:6px;
                                                background:#e9ecef; display:flex;
                                                align-items:center; justify-content:center;">
                                                <i class="bi bi-image text-muted" style="font-size:1rem;"></i>
                                            </div>
                                        }

                                        <div>
                                            <span class="badge @(isAdded ? "bg-success" : "bg-danger") me-1">
                                                @log.Action
                                            </span>
                                            <strong>"@log.ProductName"</strong>
                                            <span class="text-muted ms-1" style="font-size:0.85rem;">
                                                (@log.CategoryName)
                                            </span>
                                            <span class="text-muted ms-2" style="font-size:0.88rem;">
                                                by <strong>@log.PerformedBy</strong>
                                            </span>
                                        </div>
                                    </div>

                                    <!-- RIGHT: time + delete — FIX 3: form uses inline-flex to align properly -->
                                    <div style="display:flex; align-items:center; gap:12px; flex-shrink:0;">
                                        <small class="text-muted" style="white-space:nowrap;">
                                            <i class="bi bi-clock me-1"></i>
                                            @{
                                                var logDate = (DateTime)log.PerformedAt;
                                            }
                                            @logDate.ToString("dd MMM yyyy, hh:mm tt")
                                        </small>

                                        <form asp-action="DeleteProductMasterLog" method="post"
                                              onsubmit="return confirm('Delete this log?')"
                                              style="margin:0; padding:0; display:inline-flex; align-items:center;">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="id" value="@log.Id" />
                                            <button type="submit"
                                                    style="background:none; border:none; padding:0;
                                                color:#dc3545; font-size:0.8rem;
                                                cursor:pointer; font-weight:500;
                                                display:inline-flex; align-items:center; gap:4px;
                                                line-height:1;">
                                                <i class="bi bi-trash"></i> Delete
                                            </button>
                                        </form>
                                    </div>

                                </div>
                            </div>
                        </div>
                    }
                </div>

                <!-- FIX 4: Log pagination — changed btn-secondary to btn-primary (blue) -->
                <div style="display:flex; gap:8px; flex-wrap:wrap; margin-top:10px;">
                    @if (ViewBag.LogCurrentPage > 1)
                    {
                        <a href="@Url.Action("ManageProducts", new { page = ViewBag.CurrentPage, logPage = ViewBag.LogCurrentPage - 1 })"
                           class="btn btn-sm btn-outline-primary">&#8592; Prev</a>
                    }
                    @for (int p = 1; p <= ViewBag.LogTotalPages; p++)
                    {
                        <a href="@Url.Action("ManageProducts", new { page = ViewBag.CurrentPage, logPage = p })"
                           class="btn btn-sm @(p == (int)ViewBag.LogCurrentPage ? "btn-primary" : "btn-outline-primary")">@p</a>
                    }
                    @if (ViewBag.LogCurrentPage < ViewBag.LogTotalPages)
                    {
                        <a href="@Url.Action("ManageProducts", new { page = ViewBag.CurrentPage, logPage = ViewBag.LogCurrentPage + 1 })"
                           class="btn btn-sm btn-outline-primary">Next &#8594;</a>
                    }
                </div>
            }
            else
            {
                <p class="text-muted mt-2">No activity recorded yet.</p>
            }
        </div>
    }

</div>

@section Scripts {
    <script>
        document.getElementById('imageInput').addEventListener('change', function () {
            var preview = document.getElementById('imagePreview');
            var file = this.files[0];
            if (file) {
                var reader = new FileReader();
                reader.onload = function (e) {
                    preview.src = e.target.result;
                    preview.style.display = 'block';
                };
                reader.readAsDataURL(file);
            } else {
                preview.style.display = 'none';
            }
        });
    </script>
}