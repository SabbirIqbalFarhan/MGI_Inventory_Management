@await Html.PartialAsync("_BackButton")

<div class="container mt-4">

    <div class="p-3 text-white rounded shadow mb-4" style="background:#00aaff;">
        <h4 class="mb-0">Manage Categories</h4>
    </div>

    @if (TempData["CategorySuccess"] != null)
    {
        <div class="alert alert-success">@TempData["CategorySuccess"]</div>
    }
    @if (TempData["CategoryError"] != null)
    {
        <div class="alert alert-danger">@TempData["CategoryError"]</div>
    }

    <!-- ADD CATEGORY FORM -->
    <div class="card p-4 shadow mb-4">
        <h5 style="color:#00aaff;">Add New Category</h5>
        <form asp-action="AddCategory" method="post">
            @Html.AntiForgeryToken()
            <div class="d-flex align-items-center gap-3">
                <div style="flex:1;">
                    <label class="form-label fw-bold">Category Name</label>
                    <input type="text" name="categoryName" class="form-control"
                           style="height:38px;"
                           placeholder="e.g. Food & Beverage" required />
                </div>
                <div style="flex-shrink:0; padding-top:30px;">
                    <button type="submit" class="btn btn-primary"
                            style="height:38px; padding:0 24px;">
                        Add
                    </button>
                </div>
            </div>
        </form>
    </div>

    <!-- CATEGORY TABLE -->
    <div class="card p-4 shadow mb-4">
        <h5 style="color:#00aaff;">Category List</h5>

        @if (ViewBag.Categories != null &&
             ((IEnumerable<dynamic>)ViewBag.Categories).Any())
        {
            <table class="table table-bordered table-hover mt-2">
                <thead class="table-dark">
                    <tr>
                        <th>#</th>
                        <th>Category Name</th>
                        <th>Action</th>
                    </tr>
                </thead>
                <tbody>
                    @{
                        int c = (ViewBag.CurrentPage - 1) * 10 + 1;
                    }
                    @foreach (var cat in ViewBag.Categories)
                    {
                        <tr>
                            <td>@c</td>
                            <td>@cat.Name</td>
                            <td>
                                <form asp-action="DeleteCategory" method="post"
                                      style="display:inline"
                                      onsubmit="return confirm('Delete this category?')">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="id" value="@cat.Id" />
                                    <button type="submit" class="btn btn-sm btn-danger">
                                        Delete
                                    </button>
                                </form>
                            </td>
                        </tr>
                        c++;
                    }
                </tbody>
            </table>

            <!-- PAGINATION -->
            <div style="display:flex; gap:8px; flex-wrap:wrap; margin-top:10px;">
                @if (ViewBag.CurrentPage > 1)
                {
                    <a href="@Url.Action("ManageCategories", new { page = ViewBag.CurrentPage - 1 })"
                       class="btn btn-sm btn-outline-primary">&#8592; Prev</a>
                }
                @for (int i = 1; i <= ViewBag.TotalPages; i++)
                {
                    <a href="@Url.Action("ManageCategories", new { page = i })"
                       class="btn btn-sm @(i == (int)ViewBag.CurrentPage ? "btn-primary" : "btn-outline-primary")">@i</a>
                }
                @if (ViewBag.CurrentPage < ViewBag.TotalPages)
                {
                    <a href="@Url.Action("ManageCategories", new { page = ViewBag.CurrentPage + 1 })"
                       class="btn btn-sm btn-outline-primary">Next &#8594;</a>
                }
            </div>
        }
        else
        {
            <p class="text-muted mt-2">No categories yet.</p>
        }
    </div>

    <!-- ACTIVITY LOG — Admin only -->
    @if (User.IsInRole("Admin"))
    {
        <div class="card p-4 shadow">
            <h5 style="color:#00aaff;">
                <i class="bi bi-journal-text me-2"></i>Category Activity Log
            </h5>

            @if (ViewBag.CategoryLogs != null &&
                 ((IEnumerable<dynamic>)ViewBag.CategoryLogs).Any())
            {
                <div class="mt-3">
                    @foreach (var log in ViewBag.CategoryLogs)
                    {
                        bool isAdded = log.Action.ToString() == "Added";

                        <div style="display:flex; gap:14px; align-items:center;
                            margin-bottom:14px;">

                            <!-- ICON CIRCLE -->
                            <div style="width:38px; height:38px; border-radius:50%;
                                background:@(isAdded ? "#198754" : "#dc3545");
                                display:flex; align-items:center;
                                justify-content:center; flex-shrink:0;">
                                <i class="bi @(isAdded ? "bi-plus-lg" : "bi-trash")"
                                   style="color:white; font-size:0.9rem;"></i>
                            </div>

                            <!-- LOG BUBBLE -->
                            <div style="flex:1; background:#f8f9fa;
                                border-radius:8px; padding:10px 14px;">
                                <div style="display:flex; justify-content:space-between;
                                    flex-wrap:wrap; gap:8px; align-items:center;">

                                    <!-- LEFT: text -->
                                    <div>
                                        <span class="badge @(isAdded ? "bg-success" : "bg-danger") me-2">
                                            @log.Action
                                        </span>
                                        <strong>"@log.CategoryName"</strong>
                                        <span class="text-muted ms-2" style="font-size:0.88rem;">
                                            by <strong>@log.PerformedBy</strong>
                                        </span>
                                    </div>

                                    <!-- FIX 2: RIGHT — time + delete, inline-flex aligned -->
                                    <div style="display:flex; align-items:center; gap:12px; flex-shrink:0;">
                                        <small class="text-muted" style="white-space:nowrap;">
                                            <i class="bi bi-clock me-1"></i>
                                            @{
                                                var logDate = (DateTime)log.PerformedAt;
                                            }
                                            @logDate.ToString("dd MMM yyyy, hh:mm tt")
                                        </small>

                                        <form asp-action="DeleteCategoryLog" method="post"
                                              onsubmit="return confirm('Delete this log entry?')"
                                              style="margin:0; padding:0; display:inline-flex; align-items:center;">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="id" value="@log.Id" />
                                            <button type="submit"
                                                    style="background:none; border:none; padding:0;
                                                color:#dc3545; font-size:0.8rem;
                                                cursor:pointer; font-weight:500;
                                                display:inline-flex; align-items:center; gap:4px;
                                                line-height:1;">
                                                <i class="bi bi-trash"></i> Delete
                                            </button>
                                        </form>
                                    </div>

                                </div>
                            </div>
                        </div>
                    }
                </div>

                <!-- FIX 3: Log pagination — grey → blue -->
                <div style="display:flex; gap:8px; flex-wrap:wrap; margin-top:10px;">
                    @if (ViewBag.LogCurrentPage > 1)
                    {
                        <a href="@Url.Action("ManageCategories", new { page = ViewBag.CurrentPage, logPage = ViewBag.LogCurrentPage - 1 })"
                           class="btn btn-sm btn-outline-primary">&#8592; Prev</a>
                    }
                    @for (int i = 1; i <= ViewBag.LogTotalPages; i++)
                    {
                        <a href="@Url.Action("ManageCategories", new { page = ViewBag.CurrentPage, logPage = i })"
                           class="btn btn-sm @(i == (int)ViewBag.LogCurrentPage ? "btn-primary" : "btn-outline-primary")">@i</a>
                    }
                    @if (ViewBag.LogCurrentPage < ViewBag.LogTotalPages)
                    {
                        <a href="@Url.Action("ManageCategories", new { page = ViewBag.CurrentPage, logPage = ViewBag.LogCurrentPage + 1 })"
                           class="btn btn-sm btn-outline-primary">Next &#8594;</a>
                    }
                </div>
            }
            else
            {
                <p class="text-muted mt-2">No activity recorded yet.</p>
            }
        </div>
    }

</div>