@{
    ViewData["Title"] = "Add Role";
}

<div class="container mt-4">

    <div class="p-3 text-white rounded" style="background:#00aaff;">
        <h3>Add Role</h3>
    </div>

    <div class="card p-4 mt-3 shadow">

        <input class="form-control mb-2" placeholder="User Name" />

        <select class="form-control mb-2">
            <option>Manager</option>
            <option>Supplier</option>
            <option>Seller</option>
        </select>

        <button class="btn text-white" style="background:#00aaff;">
            Assign Role
        </button>

    </div>

</div>