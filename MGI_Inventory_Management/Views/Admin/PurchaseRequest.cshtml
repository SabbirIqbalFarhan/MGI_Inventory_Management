@await Html.PartialAsync("_BackButton")

<div class="container mt-4">

    <div class="p-3 text-white rounded shadow mb-4" style="background:#00aaff;">
        <h4 class="mb-0">Purchase Requests</h4>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success">@TempData["Success"]</div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger">@TempData["Error"]</div>
    }

    <div class="text-end mb-3">
        <a asp-action="PurchaseProduct" class="btn btn-primary">+ Make New Purchase</a>
    </div>

    @if (ViewBag.Purchases != null && ((IEnumerable<dynamic>)ViewBag.Purchases).Any())
    {
        @foreach (var purchase in ViewBag.Purchases)
        {
            <div class="card shadow mb-4">

                <!-- CARD HEADER -->
                <div class="card-header d-flex justify-content-between align-items-center"
                     style="background:#f0f8ff;">
                    <div>
                        <strong>Purchase #@purchase.Id</strong> &nbsp;|&nbsp;
                        <span>@purchase.PurchasedBy</span> &nbsp;|&nbsp;
                        <span>@purchase.PurchaseDate.ToString("dd MMM yyyy hh:mm tt")</span>
                    </div>
                    <div>
                        @if (purchase.Status == "Pending")
                        {
                            <span class="badge bg-warning text-dark">Pending</span>
                        }
                        else if (purchase.Status == "Approved")
                        {
                            <span class="badge bg-success">Approved</span>
                        }
                        else
                        {
                            <span class="badge bg-primary">Delivered</span>
                        }
                    </div>
                </div>

                <!-- CARD BODY -->
                <div class="card-body">
                    <table class="table table-bordered table-sm">
                        <thead class="table-dark">
                            <tr>
                                <th>#</th>
                                <th>Category</th>
                                <th>Product</th>
                                <th>Qty</th>
                                <th>Unit Price (BDT)</th>
                                <th>Total (BDT)</th>
                            </tr>
                        </thead>
                        <tbody>
                            @{
                                int s = 1;
                            }
                            @foreach (var item in purchase.Items)
                            {
                                <tr>
                                    <td>@s</td>
                                    <td>@item.Category?.Name</td>
                                    <td>@item.ProductName</td>
                                    <td>@item.Quantity</td>
                                    <td>@item.PurchasePrice.ToString("F2")</td>
                                    <td>@((item.Quantity * item.PurchasePrice).ToString("F2"))</td>
                                </tr>
                                s++;
                            }
                        </tbody>
                        <tfoot>
                            <tr>
                                <td colspan="5" class="text-end fw-bold">Grand Total:</td>
                                <td class="fw-bold" style="color:#00aaff;">
                                    @((purchase.Items as IEnumerable<MGI_Inventory_Management.Models.PurchaseItem>)
                                        .Sum(i => i.Quantity * i.PurchasePrice).ToString("F2")) BDT
                                </td>
                            </tr>
                        </tfoot>
                    </table>

                    <!-- ACTION BUTTONS -->
                    <div class="d-flex gap-2 mt-2">

                        @if (purchase.Status == "Pending")
                        {
                            <!-- Approve -->
                            <form asp-action="ApprovePurchase" method="post">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="id" value="@purchase.Id" />
                                <button type="submit" class="btn btn-sm btn-success">
                                    Approve
                                </button>
                            </form>

                            <!-- Delete -->
                            <form asp-action="DeletePurchase" method="post"
                                  onsubmit="return confirm('Delete this purchase request?')">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="id" value="@purchase.Id" />
                                <button type="submit" class="btn btn-sm btn-danger">Delete</button>
                            </form>
                        }

                        @if (purchase.Status == "Approved")
                        {
                            <!-- Mark Delivered → STOCK ADDED HERE -->
                            <form asp-action="DeliverPurchase" method="post">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="id" value="@purchase.Id" />
                                <button type="submit" class="btn btn-sm btn-primary">
                                    Mark as Delivered
                                </button>
                            </form>
                        }

                        @if (purchase.Status == "Delivered")
                        {
                            <span class="text-success fw-bold">✔ Delivered & Stock Updated</span>
                        }

                    </div>
                </div>

            </div>
        }

        <!-- PAGINATION -->
        <div style="display:flex; gap:8px; flex-wrap:wrap; margin-top:10px;">
            @if (ViewBag.CurrentPage > 1)
            {
                <a href="@Url.Action("PurchaseRequest", new { page = ViewBag.CurrentPage - 1 })"
                   class="btn btn-sm btn-outline-primary">&#8592; Prev</a>
            }
            @for (int i = 1; i <= ViewBag.TotalPages; i++)
            {
                <a href="@Url.Action("PurchaseRequest", new { page = i })"
                   class="btn btn-sm @(i == (int)ViewBag.CurrentPage ? "btn-primary" : "btn-outline-primary")">@i</a>
            }
            @if (ViewBag.CurrentPage < ViewBag.TotalPages)
            {
                <a href="@Url.Action("PurchaseRequest", new { page = ViewBag.CurrentPage + 1 })"
                   class="btn btn-sm btn-outline-primary">Next &#8594;</a>
            }
        </div>
    }
    else
    {
        <div class="alert alert-info">No purchase requests yet.</div>
    }
</div>