@{
    ViewData["Title"] = "Edit Role";
}

<div class="container mt-4">

    <!-- HEADER -->
    <div class="p-3 text-white rounded" style="background:#00aaff;">
        <h3>Edit Role</h3>
    </div>

    <!-- FORM CARD -->
    <div class="card mt-3 p-4 shadow">

        <form method="post">

            <!-- USER NAME -->
            <label class="fw-bold">User Name</label>
            <input type="text" class="form-control mb-3" value="Rahim" />

            <!-- ROLE -->
            <label class="fw-bold">Role</label>
            <select class="form-control mb-3">
                <option selected>Manager</option>
                <option>Supplier</option>
                <option>Seller</option>
            </select>

            <!-- BUTTONS -->
            <button type="submit" class="btn text-white" style="background:#00aaff;">
                Update Role
            </button>

            <a asp-controller="Admin" asp-action="ViewRoles"
               class="btn btn-secondary">
                Cancel
            </a>

        </form>

    </div>

</div>