@model MGI_Inventory_Management.Models.AddProduct

@await Html.PartialAsync("_BackButton")

<div class="container mt-4">
    <h3>Add Product</h3>

    <div asp-validation-summary="ModelOnly" class="text-danger"></div>

    <form asp-action="AddProduct" method="post">
        @Html.AntiForgeryToken()

        <div class="mb-3">
            <label class="form-label fw-bold">Category</label>
            <select id="categoryDropdown" name="CategoryId" class="form-select" required>
                <option value="">-- Select Category --</option>
                @foreach (var cat in ViewBag.Categories)
                {
                    <option value="@cat.Id">@cat.Name</option>
                }
            </select>
            <span asp-validation-for="CategoryId" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label class="form-label fw-bold">Product</label>
            <select id="productDropdown" name="Name" class="form-select" required>
                <option value="">-- Select Category First --</option>
            </select>
        </div>

        <!-- ✅ Description auto-filled from master, but editable per entry -->
        <div class="mb-3">
            <label asp-for="Description" class="form-label fw-bold"></label>
            <textarea id="descriptionField" asp-for="Description" class="form-control" rows="2"></textarea>
            <span asp-validation-for="Description" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label asp-for="Quantity" class="form-label fw-bold"></label>
            <input asp-for="Quantity" class="form-control" type="number" min="1" />
            <span asp-validation-for="Quantity" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label asp-for="PurchaseRate" class="form-label fw-bold"></label>
            <input asp-for="PurchaseRate" class="form-control" type="number" step="0.01" />
            <span asp-validation-for="PurchaseRate" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label asp-for="SellingPrice" class="form-label fw-bold"></label>
            <input asp-for="SellingPrice" class="form-control" type="number" step="0.01" />
            <span asp-validation-for="SellingPrice" class="text-danger"></span>
        </div>

        <button type="submit" class="btn btn-primary">Add Product</button>
        <a asp-action="Index" class="btn btn-secondary">Cancel</a>
    </form>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

    <script>
        document.getElementById('categoryDropdown').addEventListener('change', function () {
            var categoryId = this.value;
            var productDropdown = document.getElementById('productDropdown');
            var descriptionField = document.getElementById('descriptionField');

            productDropdown.innerHTML = '<option value="">Loading...</option>';
            descriptionField.value = '';

            if (!categoryId) {
                productDropdown.innerHTML = '<option value="">-- Select Category First --</option>';
                return;
            }

            fetch('/Admin/GetProductsByCategory?categoryId=' + categoryId)
                .then(response => response.json())
                .then(data => {
                    if (data.length === 0) {
                        productDropdown.innerHTML = '<option value="">No products under this category</option>';
                    } else {
                        productDropdown.innerHTML = '<option value="">-- Select Product --</option>';
                        data.forEach(function (item) {
                            var option = document.createElement('option');
                            option.value = item.productName;
                            option.text  = item.productName;
                            // ✅ Store description in data attribute
                            option.setAttribute('data-description', item.description);
                            productDropdown.appendChild(option);
                        });
                    }
                });
        });

        // ✅ Auto-fill description when product is selected
        document.getElementById('productDropdown').addEventListener('change', function () {
            var selectedOption = this.options[this.selectedIndex];
            var description = selectedOption.getAttribute('data-description');
            var descriptionField = document.getElementById('descriptionField');

            if (description) {
                descriptionField.value = description;
            } else {
                descriptionField.value = '';
            }
        });
    </script>
}