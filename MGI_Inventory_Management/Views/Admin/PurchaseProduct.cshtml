@await Html.PartialAsync("_BackButton")

<div class="container mt-4">
    <div class="p-3 text-white rounded shadow mb-4" style="background:#198754;">
        <h4 class="mb-0 text-white">Make Purchase</h4>
    </div>

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger">@TempData["Error"]</div>
    }

    <div class="card p-4 shadow">
        <form asp-action="PurchaseProduct" method="post">
            @Html.AntiForgeryToken()

            <!-- WHO IS MAKING THE PURCHASE — auto filled, read only -->
            <div class="mb-3">
                <label class="fw-bold form-label">Purchase Made By</label>
                <input type="text" class="form-control"
                       value="@ViewBag.CurrentUserLabel"
                       readonly
                       style="background:#f0f0f0; cursor:not-allowed;" />
                <input type="hidden" name="purchasedBy" value="@ViewBag.CurrentUserLabel" />
            </div>

            <!-- SUPPLIER SELECTION — Admin and Manager only -->
            @if (User.IsInRole("Admin") || User.IsInRole("Manager"))
            {
                <div class="mb-3">
                    <label class="fw-bold form-label">
                        Assign Supplier
                        <span class="text-muted fw-normal" style="font-size:0.85rem;">
                            (optional)
                        </span>
                    </label>
                    <select name="supplierUserId" class="form-select" id="supplierDropdown">
                        <option value="">-- Select Supplier --</option>
                    </select>
                </div>
            }

            <!-- SHOP INFO -->
            <div class="row g-3 mb-3">
                <div class="col-md-4">
                    <label class="fw-bold form-label">Shop Name</label>
                    <input type="text" name="shopName" class="form-control"
                           placeholder="e.g. ABC Store" />
                </div>
                <div class="col-md-4">
                    <label class="fw-bold form-label">Shop Address</label>
                    <input type="text" name="shopAddress" class="form-control"
                           placeholder="e.g. Dhaka, Bangladesh" />
                </div>
                <div class="col-md-4">
                    <label class="fw-bold form-label">Shop Contact</label>
                    <input type="text" name="shopContact" class="form-control"
                           placeholder="e.g. 01700000000" />
                </div>
            </div>

            <hr />

            <!-- PURCHASE ITEMS -->
            <h5 style="color:#198754;" class="mb-3">Purchase Items</h5>
            <div id="purchaseItemsContainer"></div>

            <button type="button" class="btn btn-outline-success btn-sm mt-2"
                    onclick="addPurchaseRow()">
                <i class="bi bi-plus-lg me-1"></i>Add Another Item
            </button>

            <hr />

            <button type="submit" class="btn text-white px-4"
                    style="background:#198754;">
                <i class="bi bi-bag-check-fill me-1"></i>Submit Purchase
            </button>
        </form>
    </div>
</div>

@section Scripts {
    <script>
        var preCategory  = @(ViewBag.PrefilledCategoryId ?? 0);
        var preProduct   = '@(Html.Raw(ViewBag.PrefilledProductName ?? ""))';
        var preUnitPrice = @(ViewBag.PrefilledUnitPrice ?? 0);
        var rowIndex     = 0;

        // Load suppliers for Admin/Manager
        @if (User.IsInRole("Admin") || User.IsInRole("Manager"))
        {
                <text>
                    fetch('/Admin/GetSuppliers')
                        .then(r => r.json())
                        .then(suppliers => {
                            var dd = document.getElementById('supplierDropdown');
                            suppliers.forEach(s => {
                                var opt = document.createElement('option');
                                opt.value = s.id;
                                opt.textContent = s.fullName || s.email;
                                dd.appendChild(opt);
                            });
                        });
                </text>
        }

        function addPurchaseRow(catId, prodName, unitPrice) {
            var container = document.getElementById('purchaseItemsContainer');
            var idx = rowIndex++;
            var div = document.createElement('div');
            div.className = 'purchase-row mb-3 p-3';
            div.style = 'background:#f8f9fa; border-radius:8px; border:1px solid #dee2e6;';
            div.id = 'purchaseRow_' + idx;
            div.innerHTML = `
                <div class="row g-2 align-items-end">
                    <div class="col-md-3">
                        <label class="form-label fw-bold" style="font-size:0.85rem;">Category</label>
                        <select name="categoryIds" class="form-select form-select-sm"
                                onchange="loadPurchaseProducts(this, ${idx})"
                                id="pcat_${idx}">
                            <option value="">-- Select --</option>
                            @foreach (var cat in ViewBag.Categories)
                            {
                                    <text>
                                        var o = document.createElement('option');
                                        o.value = '@cat.Id';
                                        o.textContent = '@cat.Name';
                                        document.getElementById('pcat_${idx}').appendChild(o);
                                    </text>
                            }
                        </select>
                    </div>
                    <div class="col-md-3">
                        <label class="form-label fw-bold" style="font-size:0.85rem;">Product</label>
                        <select name="productNames" class="form-select form-select-sm"
                                id="pprod_${idx}"
                                onchange="fetchPurchaseRate(this, ${idx})">
                            <option value="">-- Select Category First --</option>
                        </select>
                    </div>
                    <div class="col-md-2">
                        <label class="form-label fw-bold" style="font-size:0.85rem;">Purchase Rate</label>
                        <input type="number" name="purchasePrices" id="punitPrice_${idx}"
                               class="form-control form-control-sm"
                               step="0.01" min="0" />
                    </div>
                    <div class="col-md-2">
                        <label class="form-label fw-bold" style="font-size:0.85rem;">Quantity</label>
                        <input type="number" name="quantities" class="form-control form-control-sm"
                               min="1" value="1" />
                    </div>
                    <div class="col-md-2">
                        <button type="button" class="btn btn-sm btn-danger w-100"
                                onclick="removePurchaseRow('purchaseRow_${idx}')">
                            <i class="bi bi-trash-fill"></i> Remove
                        </button>
                    </div>
                </div>`;
            container.appendChild(div);

            if (catId && catId > 0) {
                var catSel = document.getElementById('pcat_' + idx);
                catSel.value = catId;
                loadPurchaseProducts(catSel, idx, prodName, unitPrice);
            }
        }

        function loadPurchaseProducts(catSelect, idx, preSelectProduct, preSelectPrice) {
            var categoryId = catSelect.value;
            var prodSelect = document.getElementById('pprod_' + idx);
            prodSelect.innerHTML = '<option value="">Loading...</option>';

            fetch('/Admin/GetProductsByCategory?categoryId=' + categoryId)
                .then(r => r.json())
                .then(products => {
                    prodSelect.innerHTML = '<option value="">-- Select Product --</option>';
                    products.forEach(p => {
                        var opt = document.createElement('option');
                        opt.value = p.productName;
                        opt.textContent = p.productName;
                        prodSelect.appendChild(opt);
                    });

                    if (preSelectProduct) {
                        prodSelect.value = preSelectProduct;
                    }

                    if (preSelectPrice && preSelectPrice > 0) {
                        document.getElementById('punitPrice_' + idx).value = preSelectPrice;
                    } else if (preSelectProduct) {
                        fetchPurchaseRate(prodSelect, idx);
                    }
                });
        }

        function fetchPurchaseRate(prodSelect, idx) {
            var productName = prodSelect.value;
            var catSelect   = document.getElementById('pcat_' + idx);
            var categoryId  = catSelect ? catSelect.value : 0;

            if (!productName || !categoryId) return;

            fetch('/Admin/GetPurchaseRate?productName=' + encodeURIComponent(productName)
                  + '&categoryId=' + categoryId)
                .then(r => r.json())
                .then(data => {
                    document.getElementById('punitPrice_' + idx).value =
                        data.price > 0 ? data.price : '';
                });
        }

        function removePurchaseRow(id) {
            var el = document.getElementById(id);
            if (el) el.remove();
        }

        window.addEventListener('load', function () {
            addPurchaseRow(
                preCategory > 0 ? preCategory : null,
                preProduct || null,
                preUnitPrice > 0 ? preUnitPrice : null
            );
        });
    </script>
}