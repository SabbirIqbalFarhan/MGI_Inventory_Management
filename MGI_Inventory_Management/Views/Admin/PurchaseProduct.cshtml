@await Html.PartialAsync("_BackButton")

<div class="container mt-4">
    <div class="p-3 text-white rounded shadow mb-4" style="background:#198754;">
        <h4 class="mb-0 text-white">Make Purchase</h4>
    </div>

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger">@TempData["Error"]</div>
    }

    <div class="card p-4 shadow">
        <form asp-action="PurchaseProduct" method="post">
            @Html.AntiForgeryToken()

            <!-- WHO IS MAKING THE PURCHASE -->
            <div class="mb-3">
                <label class="fw-bold form-label">Purchase Made By</label>
                <input type="text" class="form-control"
                       value="@ViewBag.CurrentUserLabel" readonly
                       style="background:#f0f0f0; cursor:not-allowed;" />
                <input type="hidden" name="purchasedBy" value="@ViewBag.CurrentUserLabel" />
            </div>

            <!-- SUPPLIER SELECTION — mandatory -->
            @if (User.IsInRole("Admin") || User.IsInRole("Manager"))
            {
                <div class="mb-3">
                    <label class="fw-bold form-label">
                        Assign Supplier
                        <span class="text-danger">*</span>
                    </label>
                    <select name="supplierUserId" class="form-select" id="supplierDropdown" required>
                        <option value="">-- Select Supplier --</option>
                    </select>
                    <div class="invalid-feedback">Please assign a supplier.</div>
                </div>
            }

            <hr />

            <!-- PURCHASE ITEMS -->
            <h5 style="color:#198754;" class="mb-3">Purchase Items</h5>
            <div id="purchaseItemsContainer"></div>

            <button type="button" class="btn btn-outline-success btn-sm mt-2"
                    onclick="addPurchaseRow()">
                <i class="bi bi-plus-lg me-1"></i>Add Another Item
            </button>

            <hr />

            <!-- GRAND TOTAL SECTION -->
            <div style="background:#f0fff4; border:1px solid #b7ebc8;
                border-radius:10px; padding:16px 20px; margin-bottom:20px;">
                <div style="display:flex; justify-content:space-between;
                    align-items:center; flex-wrap:wrap; gap:12px;">
                    <div>
                        <div style="font-size:0.82rem; color:#555; margin-bottom:2px;">
                            Total Items
                        </div>
                        <div style="font-size:1.1rem; font-weight:700; color:#1a1a1a;"
                             id="totalItemsDisplay">
                            0 item(s)
                        </div>
                    </div>
                    <div style="text-align:right;">
                        <div style="font-size:0.82rem; color:#555; margin-bottom:2px;">
                            Grand Total
                        </div>
                        <div style="font-size:1.6rem; font-weight:700; color:#198754;"
                             id="grandTotalDisplay">
                            ৳ 0.00
                        </div>
                    </div>
                </div>
            </div>

            <button type="submit" class="btn text-white px-4" style="background:#198754;">
                <i class="bi bi-bag-check-fill me-1"></i>Submit Purchase
            </button>
        </form>
    </div>
</div>

@section Scripts {
    <script>
        var allCategories = @Html.Raw(
                    System.Text.Json.JsonSerializer.Serialize(
                            ((IEnumerable<MGI_Inventory_Management.Models.Category>)ViewBag.Categories)
                            .Select(c => new { id = c.Id, name = c.Name })
                    )
            );

        var preCategory  = @(ViewBag.PrefilledCategoryId ?? 0);
        var preProduct   = @Html.Raw(
                    System.Text.Json.JsonSerializer.Serialize((string)(ViewBag.PrefilledProductName ?? ""))
            );
        var preUnitPrice = @(ViewBag.PrefilledUnitPrice ?? 0);
        var rowIndex     = 0;

        // Load suppliers
        @if (User.IsInRole("Admin") || User.IsInRole("Manager"))
        {
                <text>
                    fetch('/Admin/GetSuppliers')
                        .then(r => r.json())
                        .then(suppliers => {
                            var dd = document.getElementById('supplierDropdown');
                            suppliers.forEach(s => {
                                var opt = document.createElement('option');
                                opt.value = s.id;
                                opt.textContent = s.fullName || s.email;
                                dd.appendChild(opt);
                            });
                        });
                </text>
        }

        // ── Recalculate grand total ──────────────────────────────────────
        function recalcTotal() {
            var rows     = document.querySelectorAll('.purchase-row');
            var grand    = 0;
            var rowCount = 0;

            rows.forEach(function(row) {
                var priceInput = row.querySelector('.js-unit-price');
                var qtyInput   = row.querySelector('.js-quantity');
                var lineEl     = row.querySelector('.js-line-total');

                var price = parseFloat(priceInput ? priceInput.value : 0) || 0;
                var qty   = parseInt(qtyInput     ? qtyInput.value   : 0) || 0;
                var line  = price * qty;

                if (lineEl) lineEl.textContent = '৳ ' + line.toFixed(2);
                grand += line;
                rowCount++;
            });

            document.getElementById('grandTotalDisplay').textContent =
                '৳ ' + grand.toFixed(2);
            document.getElementById('totalItemsDisplay').textContent =
                rowCount + ' item(s)';
        }

        // ── Build a row ──────────────────────────────────────────────────
        function addPurchaseRow(catId, prodName, unitPrice) {
            var container = document.getElementById('purchaseItemsContainer');
            var idx = rowIndex++;

            var catOptions = '<option value="">-- Select --</option>';
            allCategories.forEach(function(c) {
                catOptions += '<option value="' + c.id + '">' + c.name + '</option>';
            });

            var div = document.createElement('div');
            div.className = 'purchase-row mb-3 p-3';
            div.id = 'purchaseRow_' + idx;
            div.style.cssText =
                'background:#f8f9fa; border-radius:8px; border:1px solid #dee2e6;';

            div.innerHTML =
                '<div class="row g-2 align-items-end">' +

                    // Category
                    '<div class="col-md-3">' +
                        '<label class="form-label fw-bold" style="font-size:0.85rem;">Category</label>' +
                        '<select name="categoryIds" class="form-select form-select-sm" ' +
                                'id="pcat_' + idx + '" ' +
                                'onchange="loadPurchaseProducts(this,' + idx + ')">' +
                            catOptions +
                        '</select>' +
                    '</div>' +

                    // Product
                    '<div class="col-md-3">' +
                        '<label class="form-label fw-bold" style="font-size:0.85rem;">Product</label>' +
                        '<select name="productNames" class="form-select form-select-sm" ' +
                                'id="pprod_' + idx + '" ' +
                                'onchange="fetchPurchaseRate(this,' + idx + ')">' +
                            '<option value="">-- Select Category First --</option>' +
                        '</select>' +
                    '</div>' +

                    // Purchase Rate (editable — supplier may give different price)
                    '<div class="col-md-2">' +
                        '<label class="form-label fw-bold" style="font-size:0.85rem;">Purchase Rate (৳)</label>' +
                        '<input type="number" name="purchasePrices" id="punitPrice_' + idx + '" ' +
                               'class="form-control form-control-sm js-unit-price" ' +
                               'step="0.01" min="0" ' +
                               'oninput="recalcTotal()" />' +
                    '</div>' +

                    // Quantity
                    '<div class="col-md-2">' +
                        '<label class="form-label fw-bold" style="font-size:0.85rem;">Quantity</label>' +
                        '<input type="number" name="quantities" ' +
                               'class="form-control form-control-sm js-quantity" ' +
                               'min="1" value="1" ' +
                               'oninput="recalcTotal()" />' +
                    '</div>' +

                    // Line Total (display only)
                    '<div class="col-md-2">' +
                        '<label class="form-label fw-bold" style="font-size:0.85rem;">Line Total</label>' +
                        '<div class="form-control form-control-sm js-line-total" ' +
                             'style="background:#e8f5e9; color:#155724; ' +
                                    'font-weight:600; font-size:0.88rem; ' +
                                    'display:flex; align-items:center;">৳ 0.00</div>' +
                    '</div>' +

                '</div>';

            container.appendChild(div);
            recalcTotal();

            if (catId && catId > 0) {
                var catSel = document.getElementById('pcat_' + idx);
                catSel.value = catId;
                loadPurchaseProducts(catSel, idx, prodName, unitPrice);
            }
        }

        // ── Load products for selected category ──────────────────────────
        function loadPurchaseProducts(catSelect, idx, preSelectProduct, preSelectPrice) {
            var categoryId = catSelect.value;
            var prodSelect = document.getElementById('pprod_' + idx);
            prodSelect.innerHTML = '<option value="">Loading...</option>';

            fetch('/Admin/GetProductsByCategory?categoryId=' + categoryId)
                .then(r => r.json())
                .then(products => {
                    prodSelect.innerHTML = '<option value="">-- Select Product --</option>';
                    products.forEach(p => {
                        var opt = document.createElement('option');
                        opt.value = p.productName;
                        opt.textContent = p.productName;
                        prodSelect.appendChild(opt);
                    });

                    if (preSelectProduct) prodSelect.value = preSelectProduct;

                    if (preSelectPrice && preSelectPrice > 0) {
                        document.getElementById('punitPrice_' + idx).value = preSelectPrice;
                        recalcTotal();
                    } else if (preSelectProduct) {
                        fetchPurchaseRate(prodSelect, idx);
                    }
                });
        }

        // ── Fetch last known purchase rate when product changes ──────────
        function fetchPurchaseRate(prodSelect, idx) {
            var productName = prodSelect.value;
            var catSelect   = document.getElementById('pcat_' + idx);
            var categoryId  = catSelect ? catSelect.value : 0;
            if (!productName || !categoryId) return;

            fetch('/Admin/GetPurchaseRate?productName=' + encodeURIComponent(productName)
                  + '&categoryId=' + categoryId)
                .then(r => r.json())
                .then(data => {
                    document.getElementById('punitPrice_' + idx).value =
                        data.price > 0 ? data.price : '';
                    recalcTotal();
                });
        }

        // ── Supplier required validation before submit ───────────────────
        document.addEventListener('DOMContentLoaded', function() {
            var form = document.querySelector('form');
            form.addEventListener('submit', function(e) {
                var supplierDd = document.getElementById('supplierDropdown');
                if (supplierDd && !supplierDd.value) {
                    e.preventDefault();
                    supplierDd.classList.add('is-invalid');
                    supplierDd.focus();
                    return;
                }
                if (supplierDd) supplierDd.classList.remove('is-invalid');
            });

            // Clear validation state as soon as user picks a supplier
            var dd = document.getElementById('supplierDropdown');
            if (dd) {
                dd.addEventListener('change', function() {
                    if (this.value) this.classList.remove('is-invalid');
                });
            }
        });

        window.addEventListener('load', function () {
            addPurchaseRow(
                preCategory  > 0 ? preCategory  : null,
                preProduct        || null,
                preUnitPrice > 0  ? preUnitPrice : null
            );
        });
    </script>
}