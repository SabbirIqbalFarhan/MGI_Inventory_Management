@{
    ViewData["Title"] = "Roles";
}

<div class="container mt-4">

    <div class="p-3 text-white rounded" style="background:#00aaff;">
        <h3>User Roles</h3>
    </div>

    <div class="card mt-3 p-3 shadow">

        <table class="table table-bordered text-center">

            <tr style="background:#00aaff; color:white;">
                <th>User</th>
                <th>Role</th>
                <th>Action</th>
            </tr>

            <tr>
                <td>Rahim</td>
                <td>Manager</td>
                <td>
                    <a asp-controller="Admin" asp-action="EditRoles" class="btn btn-success btn-sm">Edit</a>
                    <button class="btn btn-danger btn-sm">Delete</button>
                </td>
            </tr>

        </table>

    </div>

</div>