@model IEnumerable<MGI_Inventory_Management.Models.UserRoleViewModel>
@await Html.PartialAsync("_BackButton")

<div class="container mt-4">
    <div class="p-3 text-white rounded shadow mb-4" style="background:#00aaff;">
        <h4 class="mb-0"><i class="bi bi-people me-2"></i>Employee Roles</h4>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success">@TempData["Success"]</div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger">@TempData["Error"]</div>
    }

    <div class="text-end mb-3">
        <a asp-action="Register" class="btn btn-primary">
            <i class="bi bi-person-plus me-1"></i> Add Employee
        </a>
    </div>

    <div class="card p-4 shadow">
        <table class="table table-bordered table-hover">
            <thead class="table-dark">
                <tr>
                    <th>#</th>
                    <th>Employee ID</th>
                    <th>Full Name</th>
                    <th>Email</th>
                    <th>Role</th>
                    <th>Department</th>
                    <th>Designation</th>
                    <th>Phone</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @{
                    int i = 1;
                }
                @foreach (var user in Model)
                {
                    <tr>
                        <td>@i</td>
                        <td>@(user.EmployeeId ?? "-")</td>
                        <td>@user.FullName</td>
                        <td>@user.Email</td>
                        <td><span class="badge bg-primary">@user.Role</span></td>
                        <td>@(user.Department ?? "-")</td>
                        <td>@(user.Designation ?? "-")</td>
                        <td>@(user.PhoneNumber ?? "-")</td>
                        <td>
                            @if (user.Role != "SuperAdmin" && user.Role != "Admin")
                            {
                                <a asp-action="EditUser" asp-route-userId="@user.UserId"
                                       class="btn btn-sm btn-warning me-1">
                                    <i class="bi bi-pencil"></i> Edit
                                </a>
                            }
                            @if (User.IsInRole("Admin") && user.Role != "SuperAdmin" && user.Role != "Admin")
                            {
                                <form asp-action="DeleteUser" method="post" style="display:inline"
                                      onsubmit="return confirm('Delete this employee?')">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="userId" value="@user.UserId" />
                                    <button type="submit" class="btn btn-sm btn-danger">
                                        <i class="bi bi-trash"></i>
                                    </button>
                                </form>
                            }
                        </td>
                    </tr>
                    i++;
                }
            </tbody>
        </table>
    </div>
</div>