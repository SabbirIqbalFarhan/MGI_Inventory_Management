@model MGI_Inventory_Management.Models.EditUserViewModel
@await Html.PartialAsync("_BackButton")

<div class="container mt-4">
    <div class="p-3 text-white rounded shadow mb-4" style="background:#00aaff;">
        <h4 class="mb-0"><i class="bi bi-pencil-square me-2"></i>Edit Employee</h4>
    </div>

    <form asp-action="EditUser" method="post">
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="UserId" />
        <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

        <!-- ACCOUNT -->
        <div class="card shadow mb-4">
            <div class="card-header fw-bold" style="background:#e8f4ff;color:#00aaff;">Account</div>
            <div class="card-body row g-3">
                <div class="col-md-4">
                    <label asp-for="Email" class="form-label fw-bold"></label>
                    <input asp-for="Email" class="form-control" />
                    <span asp-validation-for="Email" class="text-danger"></span>
                </div>
                <div class="col-md-4">
                    <label asp-for="Role" class="form-label fw-bold"></label>
                    <select asp-for="Role" class="form-select">
                        @foreach (var r in ViewBag.Roles)
                        {
                            <option value="@r">@r</option>
                        }
                    </select>
                </div>
            </div>
        </div>

        <!-- PERSONAL -->
        <div class="card shadow mb-4">
            <div class="card-header fw-bold" style="background:#e8f4ff;color:#00aaff;">Personal Information</div>
            <div class="card-body row g-3">
                <div class="col-md-4">
                    <label asp-for="FullName" class="form-label fw-bold"></label>
                    <input asp-for="FullName" class="form-control" />
                </div>
                <div class="col-md-4">
                    <label asp-for="FatherName" class="form-label fw-bold"></label>
                    <input asp-for="FatherName" class="form-control" />
                </div>
                <div class="col-md-4">
                    <label asp-for="MotherName" class="form-label fw-bold"></label>
                    <input asp-for="MotherName" class="form-control" />
                </div>
                <div class="col-md-3">
                    <label asp-for="DateOfBirth" class="form-label fw-bold"></label>
                    <input asp-for="DateOfBirth" class="form-control" type="date" />
                </div>
                <div class="col-md-3">
                    <label asp-for="Gender" class="form-label fw-bold"></label>
                    <select asp-for="Gender" class="form-select">
                        <option value="">-- Select --</option>
                        <option>Male</option>
                        <option>Female</option>
                        <option>Other</option>
                    </select>
                </div>
                <div class="col-md-3">
                    <label asp-for="NationalId" class="form-label fw-bold"></label>
                    <input asp-for="NationalId" class="form-control" />
                </div>
                <div class="col-md-3">
                    <label asp-for="PhoneNumber" class="form-label fw-bold"></label>
                    <input asp-for="PhoneNumber" class="form-control" />
                </div>
                <div class="col-md-3">
                    <label asp-for="EmergencyContact" class="form-label fw-bold"></label>
                    <input asp-for="EmergencyContact" class="form-control" />
                </div>
                <div class="col-md-4">
                    <label asp-for="PresentAddress" class="form-label fw-bold"></label>
                    <textarea asp-for="PresentAddress" class="form-control" rows="2"></textarea>
                </div>
                <div class="col-md-4">
                    <label asp-for="PermanentAddress" class="form-label fw-bold"></label>
                    <textarea asp-for="PermanentAddress" class="form-control" rows="2"></textarea>
                </div>
            </div>
        </div>

        <!-- JOB -->
        <div class="card shadow mb-4">
            <div class="card-header fw-bold" style="background:#e8f4ff;color:#00aaff;">Job Information</div>
            <div class="card-body row g-3">
                <div class="col-md-3">
                    <label asp-for="EmployeeId" class="form-label fw-bold"></label>
                    <input asp-for="EmployeeId" class="form-control" />
                </div>
                <div class="col-md-3">
                    <label asp-for="Department" class="form-label fw-bold"></label>
                    <input asp-for="Department" class="form-control" />
                </div>
                <div class="col-md-3">
                    <label asp-for="Designation" class="form-label fw-bold"></label>
                    <input asp-for="Designation" class="form-control" />
                </div>
                <div class="col-md-3">
                    <label asp-for="JoinDate" class="form-label fw-bold"></label>
                    <input asp-for="JoinDate" class="form-control" type="date" />
                </div>
                <div class="col-md-3">
                    <label asp-for="Salary" class="form-label fw-bold"></label>
                    <input asp-for="Salary" class="form-control" type="number" step="0.01" />
                </div>
            </div>
        </div>

        <div class="d-flex gap-2 mb-5">
            <button type="submit" class="btn btn-primary px-4">Save Changes</button>
            <a asp-action="ViewRoles" class="btn btn-secondary">Cancel</a>
        </div>
    </form>
</div>